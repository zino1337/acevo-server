PUID=1000 # Example host user ID for mounted volume ownership; runtime default is 0.
PGID=1000 # Example host group ID for mounted volume ownership; runtime default is 0.

STEAM_USERNAME=your_steam_username # Required Steam account name, not email.
STEAM_PASSWORD=your_steam_password # Required Steam account password for SteamCMD.
STEAM_AUTH_CODE=your_steam_guard_code # Optional Steam Guard auth code for the next SteamCMD login.

AUTO_UPDATE=true # Default true; update the dedicated server before startup.
STEAM_VALIDATE=false # Default false; validate Steam files during update.

# ACEVO_FORCE_SOFTWARE_RENDERING=true # Default true; force Proton/WineD3D and Mesa llvmpipe software rendering for no-GPU hosts.

# SERVER_LAUNCHER_JSON=/data/server_launcher.json # Default /data/server_launcher.json; optional official tool config loaded as base config when present.
# SERVER_ADMIN_PASSWORD="" # Default empty; admin password.
# SERVER_CYCLE_ENABLED=true # Default true; cycle sessions/events when supported by the server.
# SERVER_DRIVER_PASSWORD="" # Default empty; driver password.
# SERVER_HTTP_PORT=8080 # Default 8080; HTTP/listing port exposed by the server.
# SERVER_MAX_PLAYERS=20 # Default 20; maximum player slots, downscaled to the selected track maximum if too high.
# SERVER_MAX_WAITING_PLAYERS=30 # Default 30; maximum players waiting before a session starts.
# SERVER_MIN_WAITING_PLAYERS=10 # Default 10; minimum players waiting before a session starts.
# SERVER_NAME="AC EVO Nordschleife Trackday" # Default AC EVO Nordschleife Trackday; public server name.
# SERVER_RESULTS_POST_URL= # Default empty; experimental native result POST endpoint.
# SERVER_RESULTS_TOKEN= # Default empty; optional token for native result POST endpoint.
# SERVER_SPECTATOR_PASSWORD="" # Default empty; spectator password.
# SERVER_TCP_PORT=9700 # Default 9700; TCP listener port.
# SERVER_UDP_PORT=9700 # Default 9700; UDP listener port.

# EVENT_CARS=all # Default all; comma-separated car names/substrings or all.
# EVENT_CAR_CATEGORY=all # Default all; categories: Road, Race, Track, Modern, Vintage, YT, ICE, EV, Hybrid.
# EVENT_BAN_CARS= # Default empty; comma-separated car names/substrings to remove from the allowed car pool.
# EVENT_BAN_CAR_CATEGORY= # Default empty; categories to remove from the allowed car pool.
# EVENT_INITIAL_GRIP=Optimum # Default Optimum; allowed values: Green, Fast, Optimum.
# EVENT_TRACK=Nurburgring_Touristenfahrten # Default Nurburgring_Touristenfahrten; token from the reference table.
# EVENT_TYPE=Practice # Default Practice; allowed values: Practice, Race_Weekend.
# EVENT_WEATHER=Clear # Default Clear; allowed values: Clear, Scattered_Clouds, Broken_Clouds, Overcast, Drizzle, Rain, Heavy_Rain, Damp.
# EVENT_WEATHER_BEHAVIOUR=Static # Default Static; allowed values: Static, Dynamic.

# PRACTICE_DURATION_MINUTES=180 # Default 180; practice duration in minutes.
# PRACTICE_YEAR=2024 # Default 2024; practice start year.
# PRACTICE_MONTH=8 # Default 8; practice start month.
# PRACTICE_DAY=15 # Default 15; practice start day.
# PRACTICE_HOUR=14 # Default 14; practice start hour.
# PRACTICE_MAX_WAIT_TO_BOX_SECONDS=10 # Default 10; max wait to box in seconds.
# PRACTICE_MINUTE=0 # Default 0; practice start minute.
# PRACTICE_OVERTIME_WAITING_NEXT_SESSION_SECONDS=10 # Default 10; overtime before next session in seconds.
# PRACTICE_TIME_MULTIPLIER=1 # Default 1; in-game time multiplier.

# QUALIFY_DURATION_MINUTES=10 # Default 10; qualify duration in minutes, used for Race_Weekend.
# QUALIFY_YEAR=2024 # Default 2024; qualify start year, used for Race_Weekend.
# QUALIFY_MONTH=8 # Default 8; qualify start month, used for Race_Weekend.
# QUALIFY_DAY=15 # Default 15; qualify start day, used for Race_Weekend.
# QUALIFY_HOUR=16 # Default 16; qualify start hour, used for Race_Weekend.
# QUALIFY_MAX_WAIT_TO_BOX_SECONDS=10 # Default 10; max wait to box in seconds, used for Race_Weekend.
# QUALIFY_MINUTE=0 # Default 0; qualify start minute, used for Race_Weekend.
# QUALIFY_OVERTIME_WAITING_NEXT_SESSION_SECONDS=10 # Default 10; overtime before next session in seconds, used for Race_Weekend.
# QUALIFY_TIME_MULTIPLIER=1 # Default 1; in-game time multiplier, used for Race_Weekend.

# WARMUP_DURATION_MINUTES=5 # Default 5; warmup duration in minutes, used for Race_Weekend.
# WARMUP_YEAR=2024 # Default 2024; warmup start year, used for Race_Weekend.
# WARMUP_MONTH=8 # Default 8; warmup start month, used for Race_Weekend.
# WARMUP_DAY=15 # Default 15; warmup start day, used for Race_Weekend.
# WARMUP_HOUR=16 # Default 16; warmup start hour, used for Race_Weekend.
# WARMUP_MAX_WAIT_TO_BOX_SECONDS=10 # Default 10; max wait to box in seconds, used for Race_Weekend.
# WARMUP_MINUTE=0 # Default 0; warmup start minute, used for Race_Weekend.
# WARMUP_OVERTIME_WAITING_NEXT_SESSION_SECONDS=10 # Default 10; overtime before next session in seconds, used for Race_Weekend.
# WARMUP_TIME_MULTIPLIER=1 # Default 1; in-game time multiplier, used for Race_Weekend.

# RACE_DURATION_MINUTES=25 # Default 25; race duration in minutes when RACE_DURATION_TYPE=Time.
# RACE_DURATION_LAPS=10 # Default 10; race duration in laps when RACE_DURATION_TYPE=Laps.
# RACE_DURATION_TYPE=Time # Default Time; allowed values: Time, Laps.
# RACE_YEAR=2024 # Default 2024; race start year, used for Race_Weekend.
# RACE_MONTH=8 # Default 8; race start month, used for Race_Weekend.
# RACE_DAY=15 # Default 15; race start day, used for Race_Weekend.
# RACE_HOUR=16 # Default 16; race start hour, used for Race_Weekend.
# RACE_MAX_WAIT_TO_BOX_SECONDS=60 # Default 60; max wait to box in seconds, used for Race_Weekend.
# RACE_MINUTE=0 # Default 0; race start minute, used for Race_Weekend.
# RACE_OVERTIME_WAITING_NEXT_SESSION_SECONDS=10 # Default 10; overtime before next session in seconds, used for Race_Weekend.
# RACE_TIME_MULTIPLIER=1 # Default 1; in-game time multiplier, used for Race_Weekend.
